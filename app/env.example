# App Configuration
APP_NAME=HypnoPitch

# Store Deployment
GOOGLE_PLAY_JSON_KEY_PATH=/absolute/path/to/google-play-service-account.json
FASTLANE_APPLE_ID=your-apple-id@example.com
FASTLANE_ITC_TEAM_ID=your-app-store-connect-team-id
FASTLANE_TEAM_ID=your-apple-developer-team-id
APP_STORE_CONNECT_P8_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
APP_STORE_CONNECT_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_API_ISSUER=00000000-0000-0000-0000-000000000000

# Client Configuration
CLIENT_ID_PREFIX=flutter_user

# Sequencer Configuration
SEQUENCER_MAX_STEPS=128