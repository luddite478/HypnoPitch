google_play_json_key_path = ENV["GOOGLE_PLAY_JSON_KEY_PATH"]
raise "Missing GOOGLE_PLAY_JSON_KEY_PATH" if google_play_json_key_path.to_s.empty?

json_key_file(google_play_json_key_path) # Path to the json secret file - Follow https://docs.fastlane.tools/actions/supply/#setup to get one
package_name("com.hypnopitch.app") # e.g. com.krausefx.app
