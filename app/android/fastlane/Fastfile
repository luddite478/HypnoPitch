require "shellwords"

default_platform(:android)

platform :android do
  desc "Replicated Legacy Build Logic with Asset Packing"
  lane :build_prod do
    app_dir = File.expand_path("../..", __dir__)
    pad_build_script = File.join(app_dir, "build-android-pad-release.sh")
    pubspec_path = File.join(app_dir, "pubspec.yaml")
    aab_path = File.join(app_dir, "build/app/outputs/bundle/prodRelease/app-prod-release.aab")

    # Version / build number is controlled in pubspec.yaml. The PAD build script
    # handles syncing samples into the asset pack and temporarily removing
    # bundled samples/ entries from the Flutter asset list so base stays small.
    sh("cd #{app_dir.shellescape} && #{pad_build_script.shellescape}")
    v = flutter_version(pubspec_location: pubspec_path)

    upload_to_play_store(
      track: 'internal',
      version_name: v["version_name"],
      aab: aab_path
    )
  end
end